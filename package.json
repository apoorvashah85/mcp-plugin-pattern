{
  "name": "mcp-plugin-patterns",
  "version": "0.1.0",
  "description": "Demonstrates plugin-equivalent patterns (skills, hooks, evals, agent loops) via a remote MCP server using the official TypeScript SDK",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "TRANSPORT=http node dist/index.js",
    "dev": "tsc --watch"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "plugins",
    "skills",
    "hooks",
    "sampling",
    "agent-loops"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
